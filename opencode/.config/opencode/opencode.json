{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "knip": {
      "type": "local",
      "command": ["npx", "-y", "@knip/mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--storage-state",
        "/Users/juanramirez/Work/nr_react_app/.playwright-auth.json"
      ],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    // opencode mcp auth atlassian-mcp-server
    "atlassian-mcp-server": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  }
}
